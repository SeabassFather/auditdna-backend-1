// ================================================================
// AUDITDNA BACKEND - EXPRESS SERVER
// ================================================================

const express = require('express');
const cors = require('cors');
const app = express();

// ============================================================
// MIDDLEWARE
// ============================================================
app.use(cors());
app.use(express.json());

// ============================================================
// IMPORT ROUTES (ADD THIS AT THE TOP)
// ============================================================
const produceRoutes = require('../routes/produceRoutes');

// ============================================================
// ROUTES (ADD YOUR NEW ROUTE HERE)
// ============================================================
app.use('/api/produce', produceRoutes);

// Root endpoint
app.get('/', (req, res) => {
  res.json({ 
    message: 'AuditDNA Backend API',
    version: '1.0.0',
    endpoints: [
      '/api/produce/commodity/:name',
      '/api/produce/compare',
      '/api/produce/regions/:commodity',
      '/api/produce/analyze',
      '/api/produce/top',
      '/api/produce/ai-insights/:commodity'
    ]
  });
});

// ============================================================
// START SERVER
// ============================================================
const PORT = process.env.PORT || 4000;
app.listen(PORT, () => {
  console.log(`✅ AuditDNA Backend running on port ${PORT}`);
  console.log(`🌐 API: http://localhost:${PORT}`);
});