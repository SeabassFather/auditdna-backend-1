  const losers = [
    { commodity: 'Cucumber', change: -4.8, price: 18.60 },
    { commodity: 'Lettuce', change: -3.2, price: 22.10 },
    { commodity: 'Celery', change: -2.1, price: 19.50 }
  ];
  
  res.json({ 
    gainers, 
    losers,
    timestamp: new Date().toISOString()
  });
});

// GET /api/produce/ai-insights/:commodity
produceRouter.get('/ai-insights/:commodity', (req, res) => {
  const commodity = req.params.commodity;
  
  const insights = [
    `${commodity} FOB prices up 3.2% week-over-week due to supply constraints in Michoacan region.`,
    `Retail demand showing 12% increase in major metro areas, suggesting strong consumer confidence.`,
    `Freight costs stabilizing after Q4 fuel price surge; expect margin improvement next month.`,
    `Weather forecast for growing regions favorable; supply pressure expected to ease in 14-21 days.`,
    `Competitor pricing analysis shows 6% premium opportunity in Northeast markets.`
  ];
  
  res.json({
    commodity,
    insights,
    confidence: 0.87,
    generatedAt: new Date().toISOString()
  });
});

