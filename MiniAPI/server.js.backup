// GET /api/produce/commodity/:name
produceRouter.get('/commodity/:name', (req, res) => {
  const commodity = req.params.name.toLowerCase();
  const data = mockUSDAData[commodity];
  
  if (!data) {
    return res.status(404).json({ 
      error: 'Commodity not found', 
      available: Object.keys(mockUSDAData),
      timestamp: new Date().toISOString()
    });
  }
  
  const margin = data.wholesalePrice - data.costEstimate - data.freightCost;
  const marginPercent = (margin / data.wholesalePrice * 100).toFixed(2);
  const retailSpread = data.retailPrice - (data.wholesalePrice / data.volume * 1000);
  
  res.json({
    ...data,
    margin,
    marginPercent,
    retailSpread,
    timestamp: new Date().toISOString()
  });
});

// GET /api/produce/compare
produceRouter.get('/compare', (req, res) => {
  const items = req.query.items?.split(',') || [];
  const comparison = items
    .map(item => {
      const commodity = item.toLowerCase().trim();
      return mockUSDAData[commodity] || null;
    })
    .filter(Boolean);
  
  res.json({ 
    items: comparison, 
    count: comparison.length,
    timestamp: new Date().toISOString()
  });
});

// GET /api/produce/regions/:commodity
produceRouter.get('/regions/:commodity', (req, res) => {
  const commodity = req.params.commodity.toLowerCase();
  
  const regions = [
    { region: 'CA', price: 42.50, volume: 5600, trend: 'up' },
    { region: 'FL', price: 39.80, volume: 3200, trend: 'stable' },
    { region: 'MX', price: 38.20, volume: 7800, trend: 'up' },
    { region: 'TX', price: 41.10, volume: 2100, trend: 'down' }
  ];
  
  res.json({ 
    commodity, 
    regions,
    timestamp: new Date().toISOString()
  });
});

// POST /api/produce/analyze
produceRouter.post('/analyze', (req, res) => {
  const { commodity, quantity, targetMargin } = req.body;
  const data = mockUSDAData[commodity?.toLowerCase()];
  
  if (!data) {
    return res.status(404).json({ 
      error: 'Commodity not found',
      timestamp: new Date().toISOString()
    });
  }
  
  const totalCost = (data.costEstimate + data.freightCost) * quantity;
  const totalRevenue = data.wholesalePrice * quantity;
  const actualMargin = totalRevenue - totalCost;
  const actualMarginPercent = (actualMargin / totalRevenue * 100).toFixed(2);
  
  res.json({
    commodity: data.commodity,
    quantity,
    totalCost: totalCost.toFixed(2),
    totalRevenue: totalRevenue.toFixed(2),
    actualMargin: actualMargin.toFixed(2),
    actualMarginPercent,
    meetsTarget: parseFloat(actualMarginPercent) >= (targetMargin || 0),
    riskAssessment: data.riskIndex > 0.5 ? 'HIGH' : data.riskIndex > 0.3 ? 'MEDIUM' : 'LOW',
    timestamp: new Date().toISOString()
  });
});

// GET /api/produce/top
produceRouter.get('/top', (req, res) => {
  const gainers = [
    { commodity: 'Avocado', change: 8.3, price: 42.50 },
    { commodity: 'Tomato', change: 6.7, price: 24.00 },
    { commodity: 'Bell Pepper', change: 5.2, price: 31.20 }
