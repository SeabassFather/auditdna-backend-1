$jwt = "PASTE_JWT_SECRET_HERE"
$envContent = @"
# ============================================
# AUDITDNA BACKEND ENV
# ============================================
PORT=5050
NODE_ENV=development

# ============================================
# JWT
# ============================================
JWT_SECRET=$jwt

# ============================================
# PostgreSQL (machine-level vars also present)
# ============================================
PGHOST=localhost
PGPORT=5432
PGDATABASE=auditdna
PGUSER=postgres
PGPASSWORD=auditdna2026
DATABASE_URL=postgresql://postgres:auditdna2026@localhost:5432/auditdna

# ============================================
# SMTP (GoDaddy per prior setup)
# ============================================
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=saul@mexausafg.com
SMTP_PASS=

# ============================================
# APIs
# ============================================
ANTHROPIC_API_KEY=
USDA_API_KEY=
"@
$envContent | Out-File -FilePath "C:\AuditDNA\backend\.env" -Encoding utf8 -NoNewline