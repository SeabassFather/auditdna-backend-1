'use strict';

const { Pool } = require('pg');

let pool = null;

function getPool() {
  if (!pool) {
    pool = new Pool({
      host: 'localhost',
      port: 5432,
      database: 'auditdna',
      user: 'postgres',
      password: process.env.DB_PASSWORD || 'postgres'
    });

    global.db = pool;
    console.log('DB pool initialized');
  }

  return pool;
}

module.exports = getPool;