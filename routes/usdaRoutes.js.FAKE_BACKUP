// ═══════════════════════════════════════════════════════════════════════════════
// USDA ROUTES - REAL DATA ONLY
// ═══════════════════════════════════════════════════════════════════════════════
// Replaces fake data in C:\AuditDNA\frontend\backend\routes\usdaRoutes.js
// Uses REAL USDA APIs via usdaService.js
// ═══════════════════════════════════════════════════════════════════════════════

const express = require('express');
const router = express.Router();
const usdaService = require('../services/usdaService');

// ═══════════════════════════════════════════════════════════════════════════════
// 1. SEARCH COMMODITIES (500+)
// ═══════════════════════════════════════════════════════════════════════════════
// GET /api/usda/search?q=avocado
router.get('/search', async (req, res) => {
  try {
    const query = req.query.q || '';
    if (!query) {
      return res.status(400).json({ error: 'Query parameter required' });
    }

    const results = await usdaService.searchCommodities(query);
    res.json({
      query,
      count: results.length,
      results,
      source: 'USDA NASS QuickStats',
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// ═══════════════════════════════════════════════════════════════════════════════
// 2. LIVE PRICING
// ═══════════════════════════════════════════════════════════════════════════════
// GET /api/usda/prices/:commodity
router.get('/prices/:commodity', async (req, res) => {
  try {
    const commodity = req.params.commodity;
    const pricing = await usdaService.getLivePricing(commodity);
    
    res.json({
      commodity,
      pricing,
      source: 'USDA AMS Market News',
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// ═══════════════════════════════════════════════════════════════════════════════
// 3. PORT DATA
// ═══════════════════════════════════════════════════════════════════════════════
// GET /api/usda/port/:portName
router.get('/port/:portName', async (req, res) => {
  try {
    const portName = req.params.portName;
    const portData = await usdaService.getPortData(portName);
    
    res.json({
      port: portName,
      data: portData,
      source: 'USDA FAS',
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// ═══════════════════════════════════════════════════════════════════════════════
// 4. GROWERS BY REGION
// ═══════════════════════════════════════════════════════════════════════════════
// GET /api/usda/growers?state=CA&crop=AVOCADO
router.get('/growers', async (req, res) => {
  try {
    const { state, crop } = req.query;
    const growers = await usdaService.getGrowers(state, crop);
    
    res.json({
      state,
      crop,
      count: growers.length,
      growers,
      source: 'USDA Organic Integrity Database',
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

