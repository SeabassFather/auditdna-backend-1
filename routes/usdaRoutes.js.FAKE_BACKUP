    const report = await usdaService.getWeeklyReport(commodity, week);
    
    res.json({
      commodity,
      week,
      report,
      source: 'USDA AMS Market News',
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    res.status(500).json({ error: error.message });
